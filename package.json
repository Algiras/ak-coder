{
  "name": "ak-coder-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "test:coverage:check": "bun test --coverage --coverage-threshold=85",
    "format": "bunx prettier --write \"**/*.{ts,json,md}\"",
    "start": "bun run apps/cli/src/index.ts",
    "build:cli": "bun run --filter @algiras/ak-coder build",
    "postinstall": "node scripts/patch-signal-exit.mjs"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.2",
    "typescript": "^5.4.5"
  },
  "overrides": {
    "signal-exit": "^4.1.0"
  },
  "dependencies": {
    "cli-highlight": "^2.1.11"
  }
}
